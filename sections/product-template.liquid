<script>
(function(){
  function initSnap(root){
    var containers = (root || document).querySelectorAll('[data-snap]');
    containers.forEach(function(el){
      if (el.__snapInit) return;
      el.__snapInit = true;

      var slides = el.querySelectorAll('.snap-slide');
      var prevBtn = el.parentElement.querySelector('[data-snap-prev]');
      var nextBtn = el.parentElement.querySelector('[data-snap-next]');

      // Show arrows if there’s more than one slide
      if (slides.length > 1) {
        if (prevBtn) prevBtn.classList.add('is-active');
        if (nextBtn) nextBtn.classList.add('is-active');
      }

      function pageWidth(){ return el.getBoundingClientRect().width + 12; } // + gap
      function scrollByPage(dir){ el.scrollBy({ left: dir * pageWidth(), behavior: 'smooth' }); }
      if (prevBtn) prevBtn.addEventListener('click', function(){ scrollByPage(-1); });
      if (nextBtn) nextBtn.addEventListener('click', function(){ scrollByPage(1); });

      // Drag/Swipe on desktop too
      var isDown = false, startX = 0, startLeft = 0;
      el.addEventListener('pointerdown', function(e){ isDown = true; startX = e.clientX; startLeft = el.scrollLeft; el.setPointerCapture(e.pointerId); });
      el.addEventListener('pointermove', function(e){ if (!isDown) return; el.scrollLeft = startLeft - (e.clientX - startX); });
      el.addEventListener('pointerup', function(e){ isDown = false; try{ el.releasePointerCapture(e.pointerId); }catch(_){ }});
      el.addEventListener('pointercancel', function(){ isDown = false; });
    });
  }

  function ready(fn){ if (document.readyState !== 'loading') fn(); else document.addEventListener('DOMContentLoaded', fn); }
  ready(function(){
    initSnap(document);
    // Re-init when tabs/accordions are toggled
    document.addEventListener('click', function(e){
      var t = e.target;
      if (t && (t.closest('.product-tabs') || t.closest('.acor-ttl') || t.closest('[data-tab]'))) {
        setTimeout(function(){ initSnap(document); }, 50);
      }
    });
  });
})();
</script>





