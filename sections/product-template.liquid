<script>
(function(){
  "use strict";

  // ----- Scope to this product section only -----
  var root = (function(){
    try { return document.currentScript.closest('[id^="shopify-section"]') || document; }
    catch(e){ return document; }
  })();
  if (!root) return;

  function q(sel, ctx){ return (ctx||root).querySelector(sel); }
  function qa(sel, ctx){ return Array.from((ctx||root).querySelectorAll(sel)); }
  function norm(s){ return String(s==null?'':s).trim().toLowerCase(); }

  // ----- Find product JSON already on the page (no Liquid needed here) -----
  var productData = null;
  var jsonEl =
    root.querySelector('script[type="application/json"][data-product-json]') ||
    root.querySelector('script[type="application/json"][id^="ProductJson-"]') ||
    document.querySelector('script[type="application/json"][data-product-json]') ||
    document.querySelector('script[type="application/json"][id^="ProductJson-"]');
  if (jsonEl) { try { productData = JSON.parse(jsonEl.textContent); } catch(e){} }
  if (!productData || !Array.isArray(productData.variants)) return;

  // ----- Detect which option is Flavor vs Size (names first; fallback heuristics) -----
  var optionNames = productData.options || [];
  var flavorIdx = optionNames.findIndex(function(n){ return /flavo?r/i.test(n||''); });
  var sizeIdx   = optionNames.findIndex(function(n){ return /\bsize\b/i.test(n||''); });

  (function fallback(){
    if (flavorIdx >= 0 && sizeIdx >= 0 && flavorIdx !== sizeIdx) return;
    // Heuristic: the "size-like" option usually has numbers/units in values
    function vals(i){ var S=new Set(); productData.variants.forEach(v=>S.add(v['option'+(i+1)])); return Array.from(S); }
    function sizeScore(arr){ let s=0; arr.forEach(v=>{ v=String(v||''); if (/\d/.test(v)) s+=2; if (/\b(g|mg|kg|lb|oz|ct|count|serv(ing)?s?|pack|caps?|tabs?)\b/i.test(v)) s+=3; }); return s; }
    if (optionNames.length >= 2) {
      var v0=vals(0), v1=vals(1), s0=sizeScore(v0), s1=sizeScore(v1);
      if (s0!==s1){ sizeIdx = s0>s1?0:1; flavorIdx = sizeIdx===0?1:0; }
      else { sizeIdx = (v0.length<=v1.length)?0:1; flavorIdx = sizeIdx===0?1:0; }
    } else { if (flavorIdx<0) flavorIdx=0; if (sizeIdx<0) sizeIdx=Math.min(1, optionNames.length-1); }
  })();

  // ----- Read/write helpers for current selections -----
  function getSelectByIndex(idx){
    return q('.single-option-selector[data-index="option'+(idx+1)+'"]') ||
           qa('.single-option-selector')[idx] || null;
  }
  function currentVal(idx){
    var checked = q('.swatch[data-option-index="'+idx+'"] input[type="radio"]:checked');
    if (checked) return checked.value;
    var sel = getSelectByIndex(idx);
    return sel ? sel.value : null;
  }

  // Keep FLAVORS always enabled (remove theme flags that block clicks)
  function ensureFlavorsAlwaysEnabled(){
    qa('.swatch[data-option-index="'+flavorIdx+'"] .swatch-element, [data-option-index="'+flavorIdx+'"] [data-value]').forEach(function(el){
      el.classList.remove('soldout','disabled','is-disabled','unavailable');
      el.removeAttribute('disabled');
      el.removeAttribute('data-available');
      el.removeAttribute('aria-disabled');
      el.style.pointerEvents = 'auto';
      el.style.opacity = ''; el.style.filter = '';
      var input = el.querySelector('input');
      if (input){ input.disabled = false; input.removeAttribute('disabled'); input.removeAttribute('aria-disabled'); }
      var label = el.querySelector('label,button');
      if (label){ label.style.pointerEvents='auto'; label.removeAttribute('aria-disabled'); label.removeAttribute('tabindex'); }
    });
    var sel = getSelectByIndex(flavorIdx);
    if (sel) Array.prototype.forEach.call(sel.options, function(o){ o.disabled = false; });
  }

  // Compute allowed sizes for the selected flavor (using trimmed, case-insensitive compare)
  function allowedSizesForFlavor(flavorValue){
    var FL = norm(flavorValue);
    var set = new Set();
    for (var i=0;i<productData.variants.length;i++){
      var v = productData.variants[i];
      if (!v.available) continue;
      var vf = norm(v['option'+(flavorIdx+1)]);
      var vs = v['option'+(sizeIdx+1)];
      if (vf === FL && vs != null) set.add(norm(vs));
    }
    return set;
  }

  // Post-pass: ONLY gray/disable SIZE values that are not valid for the chosen FLAVOR
  function refreshSizes(){
    ensureFlavorsAlwaysEnabled();

    var flavorVal = currentVal(flavorIdx);
    var sizeEls = qa('.swatch[data-option-index="'+sizeIdx+'"] .swatch-element');
    var sizeSel = getSelectByIndex(sizeIdx);

    if (!flavorVal){
      // No flavor yet → all sizes appear available
      sizeEls.forEach(function(el){
        el.classList.remove('soldout');
        var r = el.querySelector('input'); if (r) r.disabled = false;
      });
      if (sizeSel) Array.from(sizeSel.options).forEach(function(o){ o.disabled = false; });
      return;
    }

    var allowed = allowedSizesForFlavor(flavorVal);

    // Swatch pills
    sizeEls.forEach(function(el){
      var raw = el.getAttribute('data-value');
      var ok  = allowed.has(norm(raw));
      el.classList.toggle('soldout', !ok);
      var r = el.querySelector('input');
      if (r){ r.disabled = !ok; if (!ok && r.checked) r.checked = false; }
    });

    // <select> (if present)
    if (sizeSel){
      Array.from(sizeSel.options).forEach(function(opt){
        opt.disabled = !allowed.has(norm(opt.value));
      });
      if (sizeSel.selectedOptions[0] && sizeSel.selectedOptions[0].disabled){
        var first = Array.from(sizeSel.options).find(function(o){ return !o.disabled; });
        if (first){
          sizeSel.value = first.value;
          sizeSel.dispatchEvent(new Event('change', { bubbles:true }));
        }
      }
    }
  }

  // Make ANY flavor pill clickable even if theme tries to block it
  function forceFlavor(value){
    var sel = getSelectByIndex(flavorIdx);
    if (sel && sel.value !== value){
      sel.value = value;
      sel.dispatchEvent(new Event('change', {bubbles:true}));
    }
    var radio = root.querySelector('.swatch[data-option-index="'+flavorIdx+'"] input[type="radio"][value="'+CSS.escape(value)+'"]');
    if (radio && !radio.checked){
      radio.checked = true;
      radio.dispatchEvent(new Event('change', {bubbles:true}));
    }
  }
  function flavorCaptureHandler(e){
    var node = e.target.closest('.swatch[data-option-index="'+flavorIdx+'"] .swatch-element, [data-option-index="'+flavorIdx+'"] [data-value]');
    if (!node || !root.contains(node)) return;
    var value = node.getAttribute('data-value') || (node.textContent||'').trim();
    if (!value) return;

    // Run before theme cancels the click
    e.preventDefault(); e.stopPropagation();
    ensureFlavorsAlwaysEnabled();
    forceFlavor(value);
    refreshSizes();
  }
  root.addEventListener('pointerdown', flavorCaptureHandler, true);
  root.addEventListener('mousedown',   flavorCaptureHandler, true);
  root.addEventListener('click',       flavorCaptureHandler, true);

  // Re-apply after any option change
  root.addEventListener('change', function(e){
    var t = e.target;
    var isFlavorRadio  = t.matches('.swatch[data-option-index="'+flavorIdx+'"] input[type="radio"]');
    var isFlavorSelect = t === getSelectByIndex(flavorIdx);
    if (isFlavorRadio || isFlavorSelect){
      ensureFlavorsAlwaysEnabled();
      refreshSizes();
    }
  });

  // Guard against theme re-adding disabling flags later
  var mo = new MutationObserver(function(){ ensureFlavorsAlwaysEnabled(); });
  mo.observe(root, {subtree:true, attributes:true, attributeFilter:['class','data-available','aria-disabled','disabled']});

  // Kick off
  ensureFlavorsAlwaysEnabled();
  refreshSizes();
  requestAnimationFrame(function(){ ensureFlavorsAlwaysEnabled(); refreshSizes(); });
})();
</script>






