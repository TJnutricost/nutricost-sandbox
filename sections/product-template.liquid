    	Shopify.allAvailableOptions = {};
    	Shopify.uniq = function(array) {
        var ret = [];
        for (var i = 0; i < array.length; i++) {
          if (ret.indexOf(array[i]) === -1) {
            ret.push(array[i]);
          }
        }
        return ret;
      };
    	Shopify.updateOptionsInSelector = function(selectorIndex){
    var key, selector;
    switch (selectorIndex) {
      case 0:
        key = 'root';
        selector = $('.single-option-selector:eq(0)');
        break;
      case 1:
        key = $('.single-option-selector:eq(0)').val();
        selector = $('.single-option-selector:eq(1)');
        break;
      case 2:
        key = $('.single-option-selector:eq(0)').val() + ' / ' + $('.single-option-selector:eq(1)').val();
        selector = $('.single-option-selector:eq(2)');
        break;
    }

    var initialValue = selector.val();
    var availableOptions = Shopify.optionsMap[key] || [];

    // Current selection snapshot (from selects; radios are synced to these in your theme)
    var sel = [
      $('.single-option-selector:eq(0)').val(),
      $('.single-option-selector:eq(1)').val(),
      $('.single-option-selector:eq(2)').val()
    ];

    // Context-aware availability for the swatch group we’re updating
    $('.swatch[data-option-index="' + selectorIndex + '"] .swatch-element').each(function () {
      var $el = $(this);
      var value = $el.attr('data-value');
      var isAvailable = false;

      for (var i = 0; i < window.productVariants.length; i++) {
        var v = window.productVariants[i];
        if (!v.available) continue;

        var match = true;

        // Option1
        if (selectorIndex === 0) { if (v.option1 !== value) match = false; }
        else if (sel[0] && v.option1 !== sel[0]) match = false;

        // Option2
        if (typeof v.option2 !== 'undefined') {
          if (selectorIndex === 1) { if (v.option2 !== value) match = false; }
          else if (sel[1] && v.option2 !== sel[1]) match = false;
        }

        // Option3
        if (typeof v.option3 !== 'undefined') {
          if (selectorIndex === 2) { if (v.option3 !== value) match = false; }
          else if (sel[2] && v.option3 !== sel[2]) match = false;
        }

        if (match) { isAvailable = true; break; }
      }

      var $radio = $el.find(':radio');
      if (isAvailable) {
        $el.removeClass('soldout');
        $radio.prop('disabled', false).css('pointer-events', 'auto');
      } else {
        $el.addClass('soldout');
        $radio.prop('disabled', false).css('pointer-events', 'auto'); 
      }
    });

    // Keep the select’s value if still valid and notify downstream
    if ($.inArray(initialValue, availableOptions) !== -1) {
      selector.val(initialValue);
    }
    selector.trigger('change');
  };

        Shopify.linkOptionSelectors = function(product){
          // Building our mapping object.
          for (var i=0; i<product.variants.length; i++){
            var variant = product.variants[i];
            if(variant.available){
              // Gathering values for the 1st drop-down.
              Shopify.optionsMap['root'] = Shopify.optionsMap['root'] || [];
              Shopify.optionsMap['root'].push(variant.option1);
              Shopify.optionsMap['root'] = Shopify.uniq(Shopify.optionsMap['root']);
              // Gathering values for the 2nd drop-down.
              if(product.options.length > 1){
                var key = variant.option1;
                Shopify.optionsMap[key] = Shopify.optionsMap[key] || [];
                Shopify.optionsMap[key].push(variant.option2);
                Shopify.optionsMap[key] = Shopify.uniq(Shopify.optionsMap[key]);
              }
              // Gathering values for the 3rd drop-down.
              if(product.options.length === 3){
                var key = variant.option1 + ' / ' + variant.option2;
                Shopify.optionsMap[key] = Shopify.optionsMap[key] || [];
                Shopify.optionsMap[key].push(variant.option3);
                Shopify.optionsMap[key] = Shopify.uniq(Shopify.optionsMap[key]);
              }

              // Track ALL available options regardless of combination
              Shopify.allAvailableOptions[0] = Shopify.allAvailableOptions[0] || [];
              Shopify.allAvailableOptions[0].push(variant.option1);
              Shopify.allAvailableOptions[0] = Shopify.uniq(Shopify.allAvailableOptions[0]);

              if(product.options.length > 1){
                Shopify.allAvailableOptions[1] = Shopify.allAvailableOptions[1] || [];
                Shopify.allAvailableOptions[1].push(variant.option2);
                Shopify.allAvailableOptions[1] = Shopify.uniq(Shopify.allAvailableOptions[1]);
              }

              if(product.options.length === 3){
                Shopify.allAvailableOptions[2] = Shopify.allAvailableOptions[2] || [];
                Shopify.allAvailableOptions[2].push(variant.option3);
                Shopify.allAvailableOptions[2] = Shopify.uniq(Shopify.allAvailableOptions[2]);
              }
            }
          }

          // First, clear all soldout classes to prevent flash on page load
          $('.swatch .swatch-element').removeClass('soldout');

          // Update options right away.
          Shopify.updateOptionsInSelector(0);
          if(product.options.length > 1) Shopify.updateOptionsInSelector(1);
          if(product.options.length === 3) Shopify.updateOptionsInSelector(2);
          // When there is an update in the first dropdown.
          $(".single-option-selector:eq(0)").change(function(){
            Shopify.updateOptionsInSelector(1);
            if (product.options.length === 3) Shopify.updateOptionsInSelector(2);
            return true;
          });
          // When there is an update in the second dropdown.
          $(".single-option-selector:eq(1)").change(function(){
            if(product.options.length === 3) Shopify.updateOptionsInSelector(2);
            return true;
          });
        };
        {%- if product.available and product.options.size > 1 -%}
        window.addEventListener('DOMContentLoaded',function(){
          var $addToCartForm = $('form[action="/cart/add"]');
          if(window.MutationObserver && $addToCartForm.length){
            if(typeof observer === 'object' && typeof observer.disconnect === 'function'){observer.disconnect()}
            var config = { childList: true, subtree: true };
            var observer = new MutationObserver(function(){
              observer.disconnect();
            });
            observer.observe($addToCartForm[0], config);
          }
          var product = JSON.parse(document.getElementById('ProductJson-{{ section.id }}').innerHTML);
          Shopify.linkOptionSelectors(product);

          // Immediately fix: Ensure options with ANY available variant are not marked soldout
          // Run this RIGHT AFTER linkOptionSelectors to prevent the flash
          for (var optionIndex = 0; optionIndex < product.options.length; optionIndex++) {
            $('.swatch[data-option-index="' + optionIndex + '"] .swatch-element').each(function() {
              var optionValue = $(this).attr('data-value');
              var hasAvailableVariant = false;

              // Check if this option value exists in ANY available variant
              for (var i = 0; i < product.variants.length; i++) {
                var variant = product.variants[i];
                var variantOptionValue = variant['option' + (optionIndex + 1)];

                if (variant.available && variantOptionValue === optionValue) {
                  hasAvailableVariant = true;
                  break;
                }
              }

              // Remove soldout class if option is available in any variant
              if (hasAvailableVariant) {
                $(this).removeClass('soldout');
              }
            });
          }
          // === Flavor-first: gray/strike SIZE options that aren't available for the chosen FLAVOR ===
  (function(){
    // Use the existing 'product' object defined earlier in this same block
    var optionNames = product.options || [];

    // Try to detect flavor & size indices by name, with sensible fallbacks
    var flavorIdx = optionNames.findIndex(function(n){ return /flavo?r/i.test(n || ''); });
    if (flavorIdx < 0) flavorIdx = 0;
    var sizeIdx = optionNames.findIndex(function(n){ return /\bsize\b/i.test(n || ''); });
    if (sizeIdx < 0) sizeIdx = 1;

    function currentVal(idx){
      var $checked = $('.swatch[data-option-index="'+idx+'"] input[type="radio"]:checked');
      if ($checked.length) return $checked.val();
      return $('.single-option-selector').eq(idx).val();
    }

    function availableSizesForFlavor(flavorValue){
      var map = Object.create(null);
      for (var i=0; i<product.variants.length; i++){
        var v = product.variants[i];
        if (!v.available) continue;
        if (v['option'+(flavorIdx+1)] === flavorValue){
          var sz = v['option'+(sizeIdx+1)];
          if (sz != null) map[sz] = true;
        }
      }
      return map;
    }

    function refreshSizes(){
      var flavorVal = currentVal(flavorIdx);
      var $sizeSwatches = $('.swatch[data-option-index="'+sizeIdx+'"] .swatch-element');
      var $sizeSelect   = $('.single-option-selector').eq(sizeIdx);

      if (!flavorVal){
        // No flavor chosen: show all sizes as available
        $sizeSwatches.removeClass('soldout');
        if ($sizeSelect.length) $sizeSelect.find('option').prop('disabled', false);
        return;
      }

      var allowed = availableSizesForFlavor(flavorVal);

      // Toggle SIZE swatches only (do NOT touch flavor swatches)
      $sizeSwatches.each(function(){
        var val = $(this).attr('data-value');
        var ok  = !!allowed[val];
        $(this).toggleClass('soldout', !ok);
        if (!ok){
          // If a now-invalid size was checked, uncheck it to avoid impossible combos
          $(this).find(':radio').prop('checked', false);
        }
      });

      // Toggle SIZE <select> (if your theme shows it)
      if ($sizeSelect.length){
        $sizeSelect.find('option').each(function(){
          $(this).prop('disabled', !allowed[$(this).val()]);
        });
        // If current option is disabled, switch to the first valid one
        if ($sizeSelect.find('option:selected').is(':disabled')){
          var $first = $sizeSelect.find('option:not(:disabled)').first();
          if ($first.length){
            $sizeSelect.val($first.val()).trigger('change');
          }
        }
      }
    }

    // Run once after the theme’s own updates
    setTimeout(refreshSizes, 0);

    // Re-run after any option change (defer so it runs after Shopify.updateOptionsInSelector)
    $(document).on('change.sizeCtx', '.single-option-selector, .swatch :radio', function(){
      setTimeout(refreshSizes, 0);
    });
  })();

        });
        {%- endif -%}
    {%- endif -%}

      window.productVariants = {{ product.variants | json }};
</script>

