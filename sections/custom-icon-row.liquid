{% comment %}
  Custom Icon Multi-Column Section
  Update: Single Slide View (100% Width). 
  Ensures adjacent slides are not visible until scrolled.
{% endcomment %}

{%- style -%}
  /* 1. LOAD CUSTOM FONTS */
  {{ section.settings.header_font | font_face: font_display: 'swap' }}
  {{ section.settings.block_heading_font | font_face: font_display: 'swap' }}
  {{ section.settings.block_body_font | font_face: font_display: 'swap' }}

  /* 2. SECTION CONTAINER */
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    padding-left: {{ section.settings.margin_horizontal_mobile }}px;
    padding-right: {{ section.settings.margin_horizontal_mobile }}px;
    background-color: {{ section.settings.bg_color }};
    position: relative; 
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      padding-left: {{ section.settings.margin_horizontal }}px;
      padding-right: {{ section.settings.margin_horizontal }}px;
    }
  }

  .icon-row-container-{{ section.id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    width: 100%;
    position: relative;
  }

  /* 3. HEADER STYLES */
  .ir-section-header-{{ section.id }} {
    text-align: {{ section.settings.header_alignment }};
    margin-bottom: {{ section.settings.header_margin_bottom }}px;
    max-width: {{ section.settings.header_max_width }}px;
    margin-left: auto;
    margin-right: auto;
    padding: 0 20px;
  }

  .ir-subheading-{{ section.id }} {
    display: block;
    margin-bottom: 10px;
    font-size: 12px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: {{ section.settings.header_color }};
    opacity: 0.8;
  }

  .ir-main-heading-{{ section.id }} {
    font-family: {{ section.settings.header_font.family }}, {{ section.settings.header_font.fallback_families }} !important;
    font-weight: {{ section.settings.header_font.weight }} !important;
    font-style: {{ section.settings.header_font.style }} !important;
    color: {{ section.settings.header_color }};
    margin: 0;
    line-height: 1.2;
    font-size: {{ section.settings.header_size_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .ir-main-heading-{{ section.id }} {
      font-size: {{ section.settings.header_size }}px;
    }
  }

  /* 4. GRID / CAROUSEL LAYOUT */
  .ir-grid-wrapper-{{ section.id }} {
    position: relative;
  }

  .ir-grid-{{ section.id }} {
    display: flex;
    gap: 0; 
    
    /* Mobile Carousel Logic */
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding: 0; 
    padding-bottom: 20px; 
    
    scrollbar-width: none;  
    -ms-overflow-style: none;
    scroll-behavior: smooth;
  }
  
  .ir-grid-{{ section.id }}::-webkit-scrollbar {
    display: none; 
  }

  .ir-column-{{ section.id }} {
    display: flex;
    flex-direction: column;
    align-items: {{ section.settings.block_alignment }};
    text-align: {{ section.settings.block_alignment }};
    
    /* Mobile Item Sizing: 100% forces single slide view */
    flex: 0 0 100%; 
    width: 100%;
    scroll-snap-align: center;
    
    /* Side padding prevents text from touching screen edges */
    padding: 0 20px; 
  }

  /* CAROUSEL CONTROLS (Mobile Only) */
  .ir-controls-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 15px;
    margin-top: 10px;
  }

  .ir-arrow-{{ section.id }} {
    background: none;
    border: 1px solid {{ section.settings.header_color }};
    border-radius: 50%;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0.7;
    color: {{ section.settings.header_color }};
  }
  
  .ir-dots-{{ section.id }} {
    display: flex;
    gap: 8px;
  }

  .ir-dot-{{ section.id }} {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: {{ section.settings.header_color }};
    opacity: 0.2;
    cursor: pointer;
    transition: opacity 0.3s;
  }
  
  .ir-dot-{{ section.id }}.active {
    opacity: 1;
  }

  /* DESKTOP RESET - Switch back to standard grid */
  @media screen and (min-width: 750px) {
    .ir-grid-{{ section.id }} {
      flex-wrap: nowrap; 
      overflow-x: visible;
      padding: 0;
      justify-content: center;
      gap: {{ section.settings.grid_gap }}px; /* Desktop gap is separate */
    }

    .ir-column-{{ section.id }} {
      flex: 1; 
      width: auto;
      min-width: 0;
      scroll-snap-align: none;
      padding: 0; /* Remove internal padding on desktop */
    }

    /* Hide Controls on Desktop */
    .ir-controls-{{ section.id }} {
      display: none;
    }
  }

  /* 5. ICON STYLES */
  .ir-icon-wrapper-{{ section.id }} {
    position: relative;
    overflow: hidden;
    margin-bottom: {{ section.settings.icon_margin_bottom }}px;
    width: {{ section.settings.icon_width }}px;
    border-radius: {{ section.settings.icon_radius }}px;
    
    {% if section.settings.icon_aspect_ratio != 'auto' %}
      aspect-ratio: {{ section.settings.icon_aspect_ratio }};
    {% endif %}
    
    {% if section.settings.block_alignment == 'center' %}
      margin-left: auto;
      margin-right: auto;
    {% elsif section.settings.block_alignment == 'right' %}
      margin-left: auto;
      margin-right: 0;
    {% endif %}
  }

  .ir-icon-img-{{ section.id }} {
    width: 100%;
    height: 100%;
    object-fit: {{ section.settings.icon_object_fit }};
    display: block;
  }

  /* 6. BLOCK TYPOGRAPHY */
  .ir-block-heading-{{ section.id }} {
    font-family: {{ section.settings.block_heading_font.family }}, {{ section.settings.block_heading_font.fallback_families }} !important;
    font-weight: {{ section.settings.block_heading_font.weight }} !important;
    font-style: {{ section.settings.block_heading_font.style }} !important;
    color: {{ section.settings.block_heading_color }};
    margin: 0 0 10px 0;
    line-height: 1.3;
    font-size: {{ section.settings.block_heading_size_mobile }}px;
  }

  .ir-block-body-{{ section.id }},
  .ir-block-body-{{ section.id }} p {
    font-family: {{ section.settings.block_body_font.family }}, {{ section.settings.block_body_font.fallback_families }} !important;
    font-weight: {{ section.settings.block_body_font.weight }} !important;
    font-style: {{ section.settings.block_body_font.style }} !important;
    color: {{ section.settings.block_body_color }};
    font-size: {{ section.settings.block_body_size_mobile }}px;
    line-height: 1.5;
  }

  @media screen and (min-width: 750px) {
    .ir-block-heading-{{ section.id }} {
      font-size: {{ section.settings.block_heading_size }}px;
    }
    .ir-block-body-{{ section.id }},
    .ir-block-body-{{ section.id }} p {
      font-size: {{ section.settings.block_body_size }}px;
    }
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding" id="IrSection-{{ section.id }}">
  <div class="icon-row-container-{{ section.id }}">
    
    {% if section.settings.title != blank or section.settings.subtitle != blank %}
      <div class="ir-section-header-{{ section.id }}">
        {% if section.settings.subtitle != blank %}
          <span class="ir-subheading-{{ section.id }}">{{ section.settings.subtitle }}</span>
        {% endif %}
        {% if section.settings.title != blank %}
          <h2 class="ir-main-heading-{{ section.id }}">{{ section.settings.title }}</h2>
        {% endif %}
      </div>
    {% endif %}

    <div class="ir-grid-wrapper-{{ section.id }}">
      <div class="ir-grid-{{ section.id }}" id="IrGrid-{{ section.id }}">
        {% for block in section.blocks %}
          <div class="ir-column-{{ section.id }}" {{ block.shopify_attributes }}>
            
            <div class="ir-icon-wrapper-{{ section.id }}">
              {% if block.settings.image != blank %}
                {% assign icon_class = 'ir-icon-img-' | append: section.id %}
                {{ block.settings.image | image_url: width: 600 | image_tag: 
                  loading: 'lazy', 
                  class: icon_class,
                  widths: '100, 200, 300, 400',
                  sizes: '(min-width: 750px) 20vw, 100vw'
                }}
              {% else %}
                 {% assign placeholder_class = 'ir-icon-img-' | append: section.id %}
                 {{ 'image' | placeholder_svg_tag: placeholder_class }}
              {% endif %}
            </div>

            {% if block.settings.heading != blank %}
              <h3 class="ir-block-heading-{{ section.id }}">{{ block.settings.heading }}</h3>
            {% endif %}
            
            {% if block.settings.text != blank %}
              <div class="ir-block-body-{{ section.id }}">
                {{ block.settings.text }}
              </div>
            {% endif %}

          </div>
        {% endfor %}
      </div>

      <div class="ir-controls-{{ section.id }}">
        
        {% if section.settings.carousel_show_arrows %}
          <button class="ir-arrow-{{ section.id }}" id="PrevBtn-{{ section.id }}" aria-label="Previous Slide">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
          </button>
        {% endif %}

        {% if section.settings.carousel_show_dots %}
          <div class="ir-dots-{{ section.id }}" id="Dots-{{ section.id }}">
            {% for block in section.blocks %}
              <div class="ir-dot-{{ section.id }} {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}"></div>
            {% endfor %}
          </div>
        {% endif %}

        {% if section.settings.carousel_show_arrows %}
          <button class="ir-arrow-{{ section.id }}" id="NextBtn-{{ section.id }}" aria-label="Next Slide">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
          </button>
        {% endif %}

      </div>

    </div>

  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const sectionId = "{{ section.id }}";
  const grid = document.getElementById(`IrGrid-${sectionId}`);
  const dots = document.querySelectorAll(`.ir-dot-${sectionId}`);
  const prevBtn = document.getElementById(`PrevBtn-${sectionId}`);
  const nextBtn = document.getElementById(`NextBtn-${sectionId}`);
  
  // Settings from Liquid
  const autoPlayEnabled = {{ section.settings.carousel_autoplay }};
  const autoPlaySpeed = {{ section.settings.carousel_speed }} * 1000;
  const pauseOnHover = {{ section.settings.carousel_pause_hover }};
  
  let autoPlayInterval;
  let isPaused = false;

  // --- 1. Helper Functions ---
  
  function updateDots() {
    if(!dots.length) return;
    const scrollLeft = grid.scrollLeft;
    // Item is 100% of grid width
    const itemWidth = grid.clientWidth; 
    const index = Math.round(scrollLeft / itemWidth);
    
    dots.forEach(d => d.classList.remove('active'));
    // Bounds check
    const safeIndex = Math.min(Math.max(index, 0), dots.length - 1);
    if(dots[safeIndex]) dots[safeIndex].classList.add('active');
  }

  function scrollGrid(direction) {
    const col = grid.querySelector(`.ir-column-${sectionId}`);
    if(!col) return;

    // Scroll by the width of one item
    const scrollAmount = col.offsetWidth;

    if (direction === 'next') {
      if (grid.scrollLeft + grid.clientWidth >= grid.scrollWidth - 10) {
        grid.scrollTo({ left: 0, behavior: 'smooth' });
      } else {
        grid.scrollBy({ left: scrollAmount, behavior: 'smooth' });
      }
    } else {
      grid.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
    }
  }

  // --- 2. Event Listeners ---

  grid.addEventListener('scroll', () => {
    requestAnimationFrame(updateDots);
  });

  if(nextBtn) nextBtn.addEventListener('click', () => {
    scrollGrid('next');
    resetAutoplay();
  });
  
  if(prevBtn) prevBtn.addEventListener('click', () => {
    scrollGrid('prev');
    resetAutoplay();
  });

  dots.forEach(dot => {
    dot.addEventListener('click', (e) => {
      const index = parseInt(e.target.dataset.index);
      const col = grid.querySelector(`.ir-column-${sectionId}`);
      if(col) {
        const itemWidth = col.offsetWidth;
        const targetScroll = index * itemWidth;
        grid.scrollTo({ left: targetScroll, behavior: 'smooth' });
        resetAutoplay();
      }
    });
  });

  // --- 3. Autoplay Logic ---

  function startAutoplay() {
    if (!autoPlayEnabled) return;
    if (window.innerWidth >= 750) return;

    autoPlayInterval = setInterval(() => {
      if (!isPaused) {
        scrollGrid('next');
      }
    }, autoPlaySpeed);
  }

  function stopAutoplay() {
    clearInterval(autoPlayInterval);
  }

  function resetAutoplay() {
    stopAutoplay();
    startAutoplay();
  }

  if (pauseOnHover) {
    grid.addEventListener('touchstart', () => { isPaused = true; });
    grid.addEventListener('touchend', () => { 
      setTimeout(() => { isPaused = false; }, 2000); 
    });
    
    grid.addEventListener('mouseenter', () => { isPaused = true; });
    grid.addEventListener('mouseleave', () => { isPaused = false; });
  }

  startAutoplay();

  window.addEventListener('resize', () => {
    if (window.innerWidth >= 750) {
      stopAutoplay();
    } else {
      if(!autoPlayInterval) startAutoplay();
    }
  });

});
</script>

{% schema %}
