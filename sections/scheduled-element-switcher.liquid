{% comment %}
  Section: Scheduled Element Switcher

  Purpose:
  Show/hide existing page elements by selector during a scheduled time window.

  Common uses:
  - Swap homepage hero sections
  - Reveal a promo banner
  - Swap simple images
  - Swap entire slider sections
  - Hide/show sale-specific content

  Recommended timestamp format:
  2026-07-03T00:00:00-06:00

  Notes:
  - Use timezone offsets to avoid UTC math.
  - MDT = -06:00
  - MST = -07:00
{% endcomment %}

{% liquid
  assign switcher_enabled = section.settings.enable_scheduler
  assign default_selector = section.settings.default_selector | strip
  assign scheduled_selector = section.settings.scheduled_selector | strip
  assign start_time = section.settings.start_time | strip
  assign end_time = section.settings.end_time | strip
  assign hide_default_during_window = section.settings.hide_default_during_window
  assign hide_scheduled_outside_window = section.settings.hide_scheduled_outside_window
  assign debug_mode = section.settings.debug_mode

  assign active_class = 'scheduled-element-active-' | append: section.id
%}

{% if switcher_enabled %}
  <style>
    /*
      Fast CSS fallback.
      JavaScript below also directly controls display for better reliability.
    */

    {% if scheduled_selector != blank and hide_scheduled_outside_window %}
      html:not(.{{ active_class }}) {{ scheduled_selector }} {
        display: none !important;
      }
    {% endif %}

    {% if default_selector != blank and hide_default_during_window %}
      html.{{ active_class }} {{ default_selector }} {
        display: none !important;
      }
    {% endif %}
  </style>

  <script>
    (function () {
      var sectionId = {{ section.id | json }};
      var activeClass = {{ active_class | json }};

      var config = {
        enabled: {{ switcher_enabled | json }},
        defaultSelector: {{ default_selector | json }},
        scheduledSelector: {{ scheduled_selector | json }},
        startTime: {{ start_time | json }},
        endTime: {{ end_time | json }},
        hideDefaultDuringWindow: {{ hide_default_during_window | json }},
        hideScheduledOutsideWindow: {{ hide_scheduled_outside_window | json }},
        debugMode: {{ debug_mode | json }}
      };

      if (!config.enabled) return;

      var timerId = null;
      var maxTimerDelay = 2147483647;
      var controlledAttribute = 'data-scheduled-switcher-controlled-' + sectionId;
      var hiddenAttribute = 'data-scheduled-switcher-hidden-' + sectionId;

      function normalizeSelector(selector) {
        if (!selector || typeof selector !== 'string') return '';

        selector = selector.trim();

        /*
          Allow accidental paste formats:
          id="shopify-section-template--123__hero_ABC"
          id='shopify-section-template--123__hero_ABC'
        */
        var idMatch = selector.match(/^id=["']?([^"']+)["']?$/);

        if (idMatch && idMatch[1]) {
          return '#' + idMatch[1].trim();
        }

        /*
          If they paste only the raw Shopify section id without #,
          convert it to an ID selector.
        */
        if (
          selector.indexOf('#') !== 0 &&
          selector.indexOf('.') !== 0 &&
          selector.indexOf('[') !== 0 &&
          selector.indexOf(' ') === -1 &&
          selector.indexOf(',') === -1 &&
          selector.indexOf('shopify-section-') === 0
        ) {
          return '#' + selector;
        }

        return selector;
      }

      function parseTime(value) {
        if (!value || typeof value !== 'string') return null;

        var parsed = Date.parse(value);

        if (Number.isNaN(parsed)) {
          return null;
        }

        return parsed;
      }

      function getElements(selector) {
        var normalizedSelector = normalizeSelector(selector);

        if (!normalizedSelector) return [];

        try {
          return Array.prototype.slice.call(document.querySelectorAll(normalizedSelector));
        } catch (error) {
          if (config.debugMode) {
            console.warn('[Scheduled Element Switcher] Invalid selector:', normalizedSelector, error);
          }

          return [];
        }
      }

      function rememberOriginalDisplay(element) {
        if (!element.hasAttribute(controlledAttribute)) {
          element.setAttribute(controlledAttribute, 'true');
          element.setAttribute(
            'data-scheduled-switcher-original-display-' + sectionId,
            element.style.getPropertyValue('display') || ''
          );
          element.setAttribute(
            'data-scheduled-switcher-original-display-priority-' + sectionId,
            element.style.getPropertyPriority('display') || ''
          );
        }
      }

      function hideElement(element) {
        rememberOriginalDisplay(element);
        element.setAttribute(hiddenAttribute, 'true');
        element.style.setProperty('display', 'none', 'important');
      }

      function showElement(element) {
        rememberOriginalDisplay(element);
        element.removeAttribute(hiddenAttribute);

        var originalDisplay = element.getAttribute('data-scheduled-switcher-original-display-' + sectionId) || '';
        var originalPriority = element.getAttribute('data-scheduled-switcher-original-display-priority-' + sectionId) || '';

        if (originalDisplay) {
          element.style.setProperty('display', originalDisplay, originalPriority);
        } else {
          element.style.removeProperty('display');
        }
      }

      function getDebugElement() {
        return document.querySelector('[data-scheduled-switcher-debug="' + sectionId + '"]');
      }

      function updateDebug(status, details) {
        if (!config.debugMode) return;

        var debugElement = getDebugElement();

        if (!debugElement) return;

        var defaultElements = getElements(config.defaultSelector);
        var scheduledElements = getElements(config.scheduledSelector);

        debugElement.innerHTML =
          '<strong>Scheduled Element Switcher</strong><br>' +
          'Status: ' + status + '<br>' +
          'Start: ' + (config.startTime || 'Not set') + '<br>' +
          'End: ' + (config.endTime || 'No end/revert set') + '<br>' +
          'Default selector: ' + (normalizeSelector(config.defaultSelector) || 'Not set') + '<br>' +
          'Default matches found: ' + defaultElements.length + '<br>' +
          'Scheduled selector: ' + (normalizeSelector(config.scheduledSelector) || 'Not set') + '<br>' +
          'Scheduled matches found: ' + scheduledElements.length + '<br>' +
          details;
      }

      function scheduleNextSwitch(nowMs, startMs, endMs) {
        if (timerId) {
          window.clearTimeout(timerId);
          timerId = null;
        }

        var nextSwitch = null;

        if (startMs && nowMs < startMs) {
          nextSwitch = startMs;
        } else if (startMs && endMs && nowMs >= startMs && nowMs < endMs) {
          nextSwitch = endMs;
        }

        if (!nextSwitch) return;

        var delay = nextSwitch - nowMs;

        if (delay <= 0) return;

        if (delay > maxTimerDelay) {
          delay = maxTimerDelay;
        }

        timerId = window.setTimeout(function () {
          updateScheduledState();
        }, delay + 1000);
      }

      function applyVisibility(isActive) {
        var defaultElements = getElements(config.defaultSelector);
        var scheduledElements = getElements(config.scheduledSelector);

        if (isActive) {
          if (config.hideDefaultDuringWindow) {
            defaultElements.forEach(hideElement);
          }

          scheduledElements.forEach(showElement);
        } else {
          defaultElements.forEach(showElement);

          if (config.hideScheduledOutsideWindow) {
            scheduledElements.forEach(hideElement);
          }
        }
      }

      function updateScheduledState() {
        var startMs = parseTime(config.startTime);
        var endMs = parseTime(config.endTime);
        var nowMs = Date.now();

        if (!startMs) {
          document.documentElement.classList.remove(activeClass);
          applyVisibility(false);

          updateDebug(
            'Inactive',
            '<br>Issue: Start time is missing or invalid.<br>' +
            'Current browser time: ' + new Date(nowMs).toString()
          );

          return;
        }

        if (endMs && endMs <= startMs) {
          document.documentElement.classList.remove(activeClass);
          applyVisibility(false);

          updateDebug(
            'Inactive',
            '<br>Issue: End time must be later than start time.<br>' +
            'Current browser time: ' + new Date(nowMs).toString()
          );

          return;
        }

        var isActive = nowMs >= startMs && (!endMs || nowMs < endMs);

        document.documentElement.classList.toggle(activeClass, isActive);
        applyVisibility(isActive);

        updateDebug(
          isActive ? 'Active — scheduled element is showing' : 'Inactive — default state is showing',
          '<br>Current browser time: ' + new Date(nowMs).toString()
        );

        scheduleNextSwitch(nowMs, startMs, endMs);
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', updateScheduledState);
      } else {
        updateScheduledState();
      }

      document.addEventListener('shopify:section:load', updateScheduledState);
      document.addEventListener('shopify:section:select', updateScheduledState);
      document.addEventListener('shopify:block:select', updateScheduledState);
    })();
  </script>
{% endif %}

{% if request.design_mode and debug_mode %}
  <div
    data-scheduled-switcher-debug="{{ section.id }}"
    style="
      margin: 16px auto;
      max-width: 760px;
      padding: 16px;
      border: 1px solid rgba(0, 0, 0, 0.2);
      border-radius: 8px;
      font-family: Arial, sans-serif;
      font-size: 13px;
      line-height: 1.45;
      background: #fffbe8;
      color: #111;
      position: relative;
      z-index: 9999;
    "
  >
    <strong>Scheduled Element Switcher</strong><br>
    Debug mode is enabled. Save/preview the theme to see status details.
  </div>
{% endif %}

{% schema %}
{
  "name": "Scheduled switcher",
  "tag": "section",
  "class": "scheduled-element-switcher-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_scheduler",
      "label": "Enable scheduler",
      "default": true
    },
    {
      "type": "paragraph",
      "content": "Use this section to show or hide existing page elements during a scheduled time window. Paste CSS selectors such as #shopify-section-template--123__hero_ABC123, .promo-image, or [data-promo='holiday']."
    },
    {
      "type": "text",
      "id": "default_selector",
      "label": "Default/main element selector",
      "info": "The normal element to hide during the scheduled window. Example: #shopify-section-template--123__hero_MAIN"
    },
    {
      "type": "text",
      "id": "scheduled_selector",
      "label": "Scheduled element selector",
      "info": "The sale/holiday element to show during the scheduled window. Example: #shopify-section-template--123__hero_SALE"
    },
    {
      "type": "text",
      "id": "start_time",
      "label": "Start date/time",
      "default": "2026-07-03T00:00:00-06:00",
      "info": "Use ISO format with timezone offset. Example for midnight MDT: 2026-07-03T00:00:00-06:00"
    },
    {
      "type": "text",
      "id": "end_time",
      "label": "End/revert date/time",
      "default": "2026-07-06T00:00:00-06:00",
      "info": "Leave blank if the scheduled element should stay active indefinitely. Example for midnight MDT: 2026-07-06T00:00:00-06:00"
    },
    {
      "type": "checkbox",
      "id": "hide_default_during_window",
      "label": "Hide default/main element during scheduled window",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "hide_scheduled_outside_window",
      "label": "Hide scheduled element before start and after end",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "debug_mode",
      "label": "Show debug box in theme editor",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Scheduled switcher"
    }
  ]
}
{% endschema %}