{% comment %}
  Custom 2-Column Feature Section
  Updated: stronger CSS selectors to force font application.
{% endcomment %}

{%- style -%}
  /* 1. LOAD CUSTOM FONTS */
  {{ section.settings.heading_font | font_face: font_display: 'swap' }}
  {{ section.settings.body_font | font_face: font_display: 'swap' }}

  /* 2. SECTION VARIABLES */
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    padding-left: {{ section.settings.margin_horizontal_mobile }}px;
    padding-right: {{ section.settings.margin_horizontal_mobile }}px;
    background-color: {{ section.settings.bg_color }};
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      padding-left: {{ section.settings.margin_horizontal }}px;
      padding-right: {{ section.settings.margin_horizontal }}px;
    }
  }

  .cf-container-{{ section.id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.gap_mobile }}px;
  }

  /* Desktop Layout Logic */
  @media screen and (min-width: 750px) {
    .cf-container-{{ section.id }} {
      flex-direction: row;
      align-items: {{ section.settings.vertical_alignment }};
      gap: {{ section.settings.gap_desktop }}px;
    }

    .cf-col-image-{{ section.id }} {
      width: {{ section.settings.image_col_width }}%;
      flex-shrink: 0;
    }
    
    .cf-col-text-{{ section.id }} {
      width: calc(100% - {{ section.settings.image_col_width }}% - {{ section.settings.gap_desktop }}px);
    }

    /* Layout Flip */
    {% if section.settings.layout == 'image_right' %}
      .cf-container-{{ section.id }} {
        flex-direction: row-reverse;
      }
    {% endif %}
  }

  /* Image Styling */
  .cf-image-wrapper-{{ section.id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ section.settings.image_radius }}px;
    {% if section.settings.aspect_ratio == 'custom' %}
       height: {{ section.settings.image_custom_height }}px;
    {% elsif section.settings.aspect_ratio != 'auto' %}
       aspect-ratio: {{ section.settings.aspect_ratio }};
    {% endif %}
  }

  .cf-image-{{ section.id }} {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: {{ section.settings.image_fit }};
    object-position: center;
    {% if section.settings.aspect_ratio == 'auto' %}
      height: auto;
    {% endif %}
  }

  /* Typography Styling */
  .cf-text-content-{{ section.id }} {
    padding: {{ section.settings.text_padding }}px;
    text-align: {{ section.settings.text_alignment }};
  }

  /* HEADING STYLES 
     We use !important to override global theme styles
  */
  h2.cf-heading-{{ section.id }},
  .cf-heading-{{ section.id }} {
    font-family: {{ section.settings.heading_font.family }}, {{ section.settings.heading_font.fallback_families }} !important;
    font-weight: {{ section.settings.heading_font.weight }} !important;
    font-style: {{ section.settings.heading_font.style }} !important;
    
    margin: 0;
    margin-bottom: {{ section.settings.heading_bottom_margin }}px;
    color: {{ section.settings.heading_color }};
    font-size: {{ section.settings.heading_size_mobile }}px;
    line-height: {{ section.settings.heading_line_height }};
    text-transform: {{ section.settings.heading_transform }};
    letter-spacing: {{ section.settings.heading_letter_spacing }}px;
  }

  /* BODY STYLES */
  .cf-body-{{ section.id }},
  .cf-body-{{ section.id }} p,
  .cf-body-{{ section.id }} li,
  .cf-body-{{ section.id }} a {
    font-family: {{ section.settings.body_font.family }}, {{ section.settings.body_font.fallback_families }} !important;
    font-weight: {{ section.settings.body_font.weight }} !important;
    font-style: {{ section.settings.body_font.style }} !important;
    
    margin: 0;
    color: {{ section.settings.body_color }};
    font-size: {{ section.settings.body_size_mobile }}px;
    line-height: {{ section.settings.body_line_height }};
    letter-spacing: {{ section.settings.body_letter_spacing }}px;
  }
  
  .cf-body-{{ section.id }} p {
     margin: 0 0 1em 0;
  }
  .cf-body-{{ section.id }} p:last-child {
     margin-bottom: 0;
  }

  @media screen and (min-width: 750px) {
    h2.cf-heading-{{ section.id }},
    .cf-heading-{{ section.id }} {
      font-size: {{ section.settings.heading_size }}px;
    }
    .cf-body-{{ section.id }},
    .cf-body-{{ section.id }} p,
    .cf-body-{{ section.id }} li,
    .cf-body-{{ section.id }} a {
      font-size: {{ section.settings.body_size }}px;
    }
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding">
  <div class="cf-container-{{ section.id }}">
    
    <div class="cf-col-image-{{ section.id }}">
      <div class="cf-image-wrapper-{{ section.id }}">
        {% if section.settings.image != blank %}
          {% assign img_class = 'cf-image-' | append: section.id %}
          {{ section.settings.image | image_url: width: 1500 | image_tag: 
            loading: 'lazy', 
            class: img_class,
            widths: '375, 550, 750, 1100, 1500',
            sizes: '(min-width: 750px) 50vw, 100vw'
          }}
        {% else %}
          {% assign placeholder_class = 'cf-image-' | append: section.id %}
          {{ 'image' | placeholder_svg_tag: placeholder_class }}
        {% endif %}
      </div>
    </div>

    <div class="cf-col-text-{{ section.id }}">
      <div class="cf-text-content-{{ section.id }}">
        {% if section.settings.heading != blank %}
          <h2 class="cf-heading-{{ section.id }}">{{ section.settings.heading }}</h2>
        {% endif %}
        
        {% if section.settings.text != blank %}
          <div class="cf-body-{{ section.id }}">
            {{ section.settings.text }}
          </div>
        {% endif %}
      </div>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Custom 2-Column",
  "settings": [
    {
      "type": "header",
      "content": "Section Layout"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 800,
      "max": 1800,
      "step": 20,
      "unit": "px",
      "label": "Container Max Width",
      "default": 1200
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Desktop Image Position",
      "options": [
        { "value": "image_left", "label": "Image Left" },
        { "value": "image_right", "label": "Image Right" }
      ],
      "default": "image_left"
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "Vertical Alignment",
      "options": [
        { "value": "flex-start", "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Bottom" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "image_col_width",
      "min": 20,
      "max": 80,
      "step": 1,
      "unit": "%",
      "label": "Image Column Width (%)",
      "default": 50
    },
    {
      "type": "range",
      "id": "gap_desktop",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Gap Between Columns (Desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Gap Between Columns (Mobile)",
      "default": 30
    },
    {
      "type": "header",
      "content": "Image Settings"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Image Aspect Ratio",
      "options": [
        { "value": "auto", "label": "Original Image Ratio" },
        { "value": "1/1", "label": "Square (1:1)" },
        { "value": "4/3", "label": "Landscape (4:3)" },
        { "value": "16/9", "label": "Wide (16:9)" },
        { "value": "2/3", "label": "Portrait (2:3)" },
        { "value": "custom", "label": "Fixed Height (Use slider below)" }
      ],
      "default": "1/1"
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Image Object Fit",
      "info": "Controls how the image fits within the aspect ratio.",
      "options": [
        { "value": "cover", "label": "Cover (Crop to fill)" },
        { "value": "contain", "label": "Contain (Show full image)" }
      ],
      "default": "cover"
    },
    {
      "type": "range",
      "id": "image_custom_height",
      "min": 200,
      "max": 800,
      "step": 10,
      "unit": "px",
      "label": "Fixed Image Height",
      "info": "Only works if Aspect Ratio is set to 'Fixed Height'",
      "default": 400
    },
    {
      "type": "range",
      "id": "image_radius",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Image Border Radius",
      "default": 4
    },
    {
      "type": "header",
      "content": "Typography: Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading Text",
      "default": "WHY NUTRICOST"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading Font Family",
      "info": "Select weight and style here.",
      "default": "work_sans_n7"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 16,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Heading Size (Desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 14,
      "max": 60,
      "step": 1,
      "unit": "px",
      "label": "Heading Size (Mobile)",
      "default": 28
    },
    {
      "type": "select",
      "id": "heading_transform",
      "label": "Heading Text Transform",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "lowercase", "label": "Lowercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "uppercase"
    },
    {
      "type": "range",
      "id": "heading_letter_spacing",
      "min": -5,
      "max": 10,
      "step": 0.5,
      "unit": "px",
      "label": "Heading Letter Spacing",
      "default": 0
    },
    {
      "type": "range",
      "id": "heading_bottom_margin",
      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "px",
      "label": "Margin Bottom",
      "default": 20
    },
    {
      "type": "range",
      "id": "heading_line_height",
      "min": 0.8,
      "max": 2.0,
      "step": 0.1,
      "label": "Heading Line Height",
      "default": 1.2
    },
    {
      "type": "header",
      "content": "Typography: Body"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Body Text",
      "default": "<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit...</p>"
    },
    {
      "type": "font_picker",
      "id": "body_font",
      "label": "Body Font Family",
      "default": "work_sans_n4"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body Color",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "body_size",
      "min": 12,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Body Size (Desktop)",
      "default": 16
    },
    {
      "type": "range",
      "id": "body_size_mobile",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Body Size (Mobile)",
      "default": 14
    },
    {
      "type": "range",
      "id": "body_letter_spacing",
      "min": -2,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "label": "Body Letter Spacing",
      "default": 0
    },
    {
      "type": "range",
      "id": "body_line_height",
      "min": 1.0,
      "max": 2.5,
      "step": 0.1,
      "label": "Body Line Height",
      "default": 1.6
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "text_padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Text Content Internal Padding",
      "default": 0
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Padding Top (Desktop)",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom (Desktop)",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Top (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "margin_horizontal",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Horizontal Margin (Desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "margin_horizontal_mobile",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Horizontal Margin (Mobile)",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Custom 2-Column"
    }
  ]
}
{% endschema %}