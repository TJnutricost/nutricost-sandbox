  <body
    id="{{ page_title | handle }}"
    class="template-{{ template | split: '.' | first }} {%- if settings.rtl -%}rtl {%- endif -%}lazyloaded"
    {%- if settings.bodybg_img %}
      data-bgset="{% include 'bgset', image: settings.bodybg_img %}" data-sizes="auto" data-parent-fit="cover"
      style="background-image:url('{{ settings.bodybg_img | img_url: '50x50' }});"
    {%- endif -%}
  >
    {%- unless BLOCKED_COUNTRIES contains buyer_country or request.design_mode -%}
      <!-- GTM (noscript, goes in BODY) -->
      <noscript
        ><iframe
          src="https://www.googletagmanager.com/ns.html?id=GTM-XXXXXXX"
          height="0"
          width="0"
          style="display:none;visibility:hidden"
        ></iframe
      ></noscript>
    {%- endunless -%}

    {%- if settings.enable_age_varification -%}{% render 'age-check' %}{%- endif -%}
    {%- if settings.layout_style == 'boxedlayout' -%}<div class="page-wrapper layout-boxed">{%- endif -%}
    {%- include 'header' -%}
    {%- if settings['top-information-bar'] -%}{% section 'top-info-panel' %}{%- endif -%}
    <main id="PageContainer" class="main-content {{ template | split: '.' | first }}" id="MainContent" role="main">
      {{ content_for_layout }}
    </main>
    {%- section 'footer' -%}
    {% if settings.layout_style == 'boxedlayout' %}</div>{% endif %}
    {% section 'custom-colors' %}
    {% section 'exit-product-popup' %}

    <!-- <script src="{{ 'option_selection.js' | shopify_asset_url }}" defer="defer"></script> -->
    {%- if template.directory == 'customers' -%}
      <script src="{{ 'shopify_common.js' | shopify_asset_url }}" defer="defer"></script>
    {%- endif -%}
    {%- if content_for_layout contains 'data-stellar-background-ratio' -%}
      <script type="lazyload2" data-src="{{ 'stellar.js' | asset_url }}" defer></script>
    {%- endif -%}
    {%- if content_for_layout contains 'grid-masonary' -%}
      <script src="{{ 'masonry.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}
    {%- if settings.show_multiple_currencies and settings.currency_opt == 'script' -%}
      {%- render 'currencies' -%}
    {%- endif -%}
    {%- if settings.enable_site_animation -%}<script src="{{ 'wow.min.js' | asset_url }}" defer></script>{%- endif -%}
    {% comment %} <script type="lazyload2" data-src="{{ 'theme.min.js' | asset_url }}" defer="defer"></script> {% endcomment %}
    <script src="{{ 'theme.min.js' | asset_url }}" defer></script>

    {%- render 'theme-modals' -%}
    {%- if settings.show_sticky_arrow -%}
      <span id="site-scroll"><i class="ad ad-arw-up" aria-hidden="true"></i></span>
    {%- endif -%}
    <!-- <script src="{{ 'script-loader.js' | asset_url }}" defer></script> -->
    <!-- AOD_OrderLimit Start -->
    {% include 'aodLimitValidator' %}
    <!-- AOD_OrderLimit End -->
    <script type="lazyload2" data-src="{{'tiny-img-link-preloader.js' | asset_url }}"></script>

    {%- comment -%} Disable optimizer on LoyaltyLion page template {%- endcomment -%}
    {% unless request.page_type == 'page' and template.suffix == 'loyaltylion' %}
      {% render 'optimizer' %}
    {% endunless %}
    {% section 'scheduled-element-switcher' %}
  </body>
</html>
