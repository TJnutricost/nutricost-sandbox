<!doctype html>
<html
  class="no-js"
  lang="{{ request.locale.iso_code }}"
  {% if settings.rtl %}
    dir="rtl"
  {% endif %}
>
  <script type="text/javascript" async src="https://pm.geniusmonkey.com/gm.js?id=1028352145&z=1"></script>
  <head>
    {% render 'load-metafields' %}
    {%- capture metaTags -%}
	<meta charset="utf-8">
  	<meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
	<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
	<meta name="theme-color" content="{{ settings.mob_browser }}">
	<meta name="format-detection" content="telephone=no">
	<link rel="canonical" href="{{ canonical_url }}">
	<link rel="dns-prefetch" href="https://{{shop.domain}}" crossorigin>
	<link rel="dns-prefetch" href="https://{{shop.permanent_domain}}" crossorigin>
	<link rel="dns-prefetch" href="https://cdn.shopify.com" crossorigin>
	<link rel="dns-prefetch" href="https://fonts.shopifycdn.com" crossorigin>
	<link rel="preconnect" href="https//fonts.shopifycdn.com" crossorigin>
	<link rel="preconnect" href="https//cdn.shopify.com" crossorigin>
	<link rel="preconnect" href="https//ajax.googleapis.com">
  
	<link rel="preload" as="style" href="{%- if settings.rtl -%}{{ 'themeRtl.css' | asset_url }}{%- else -%}{{ 'theme.css' | asset_url }}{%- endif -%}" />
  	<link rel="preload" href="{{ 'jquery.min.js' | asset_url }}" as="script">
  	<link rel="preload" href="{{ 'vendor.js' | asset_url }}" as="script">
    <link rel="preload" href="{{ 'theme.min.js' | asset_url }}" as="script">
    {%- if settings.favicon != blank -%}<link rel="shortcut icon" href="{{ settings.favicon | img_url: '32x32' }}" type="image/png">{%- endif -%}
    {%- if settings.favicon_retina != blank -%}<link rel="apple-touch-icon-precomposed" type="image/png" sizes="152x152" href="{{ settings.favicon_retina | img_url: '152x' }}">{%- endif -%}
  	<title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>
  	{%- if page_description -%}<meta name="description" content="{{ page_description | escape }}">{%- endif -%}
  	{%- render 'social-meta-tags' -%}
  {%- endcapture -%}
    {{ metaTags | strip_newlines | remove: '  ' | remove: '	' }}

    {%- comment -%} LoyaltyLion page-only CSS (must be outside capture) {%- endcomment -%}
    {% if request.page_type == 'page' and page.handle == 'rewards' %}
      {{ 'loyaltylion-page.css' | asset_url | stylesheet_tag }}
    {% endif %}


    {%- capture mainjs -%}
  	{%- render 'head-css' -%}
    <link rel="stylesheet" data-href="{{ 'fonts.css' | asset_url }}" type="text/css" media="all">
  	{% if settings.rtl %}
    	<link rel="stylesheet" href="{{ 'themeRtl.css' | asset_url }}" type="text/css" media="all">
  	{% else %}
  		<link rel="stylesheet" href="{{ 'theme.css' | asset_url }}" type="text/css" media="all">
  	{% endif %}

    {%- capture buyer_country -%}{{ localization.country.iso_code | upcase }}{%- endcapture -%}
{%- assign BLOCKED_COUNTRIES = 'IN' | split: ',' -%}

<script>
  // Make it easy to debug/consume in apps or GTM
  window.ANALYTICS_BLOCKED = {{ BLOCKED_COUNTRIES contains buyer_country | json }};
  window.SHOPIFY_COUNTRY   = "{{ buyer_country }}";
  window.dataLayer = window.dataLayer || [];
  window.dataLayer.push({
    shopifyCountry: "{{ buyer_country }}",
    blockedForAnalytics: window.ANALYTICS_BLOCKED
  });
</script>

