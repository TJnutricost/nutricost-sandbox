{% doc %}
  @prompt
    Create a flexible two-column section with an image block and a text block that can be positioned on either side. Include these features:
    
    - Image block with border radius control, spacing/padding options, and standard image settings
    - Text block with heading and body text, full typography controls (font family, size, weight, color), text alignment options, and independent spacing/padding
    - Layout controls to switch which side the image and text appear on (left/right)
    - Individual dimension and spacing controls for each block so they can be styled independently
    - Similar structure to the native "banner with text" section but with separated, independently controllable blocks
    
    The section should give full control over the visual spacing, positioning, and styling of both the image and text areas.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-flex-column-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-flex-column-container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: {{ block.settings.layout_direction }};
    align-items: {{ block.settings.vertical_alignment }};
    gap: {{ block.settings.column_gap }}px;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-flex-column-image-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.image_width_percent }}%;
    padding: {{ block.settings.image_padding_top }}px {{ block.settings.image_padding_right }}px {{ block.settings.image_padding_bottom }}px {{ block.settings.image_padding_left }}px;
  }

  .ai-flex-column-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-flex-column-image-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: {{ block.settings.image_fit }};
  }

  .ai-flex-column-image-placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    width: 100%;
    min-height: 300px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-flex-column-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
  }

  .ai-flex-column-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-flex-column-text-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.text_width_percent }}%;
    padding: {{ block.settings.text_padding_top }}px {{ block.settings.text_padding_right }}px {{ block.settings.text_padding_bottom }}px {{ block.settings.text_padding_left }}px;
    display: flex;
    flex-direction: column;
    justify-content: {{ block.settings.text_vertical_alignment }};
  }

  .ai-flex-column-text-content-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-flex-column-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: {{ block.settings.heading_line_height }};
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
  }

  .ai-flex-column-body-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-size: {{ block.settings.body_size }}px;
    line-height: {{ block.settings.body_line_height }};
    color: {{ block.settings.body_color }};
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-flex-column-container-{{ ai_gen_id }} {
      flex-direction: column;
      gap: {{ block.settings.mobile_gap }}px;
    }

    .ai-flex-column-image-{{ ai_gen_id }},
    .ai-flex-column-text-{{ ai_gen_id }} {
      flex: 0 0 100%;
    }

    .ai-flex-column-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-flex-column-body-{{ ai_gen_id }} {
      font-size: {{ block.settings.body_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<ai-flex-column-{{ ai_gen_id }}
  class="ai-flex-column-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-flex-column-container-{{ ai_gen_id }}">
    <div class="ai-flex-column-image-{{ ai_gen_id }}">
      <div class="ai-flex-column-image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.image %}
          <img
            src="{{ block.settings.image | image_url: width: 2000 }}"
            alt="{{ block.settings.image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
          >
        {% else %}
          <div class="ai-flex-column-image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-flex-column-empty-state-{{ ai_gen_id }}">
              Add an image to get started
            </div>
          </div>
        {% endif %}
      </div>
    </div>

    <div class="ai-flex-column-text-{{ ai_gen_id }}">
      <div class="ai-flex-column-text-content-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-flex-column-heading-{{ ai_gen_id }}">
            {{ block.settings.heading }}
          </h2>
        {% endif %}

        {% if block.settings.body_text != blank %}
          <div class="ai-flex-column-body-{{ ai_gen_id }}">
            {{ block.settings.body_text }}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</ai-flex-column-{{ ai_gen_id }}>

