nts\": { \"uuid\": \"s-37bb5f5a-7235-4926-8693-31a0a387472e\" }\n    }\n  </script>\n\n</div>\n      \n      \n      \n      \n    </div>\n  </div>\n\n<div\n    class=\"shg-box-vertical-align-wrapper\">\n    <div\n      class=\"shg-box shg-c    \"\n      \n      id=\"s-65cd778d-7d6f-4bc0-b564-dbd38c8dcebb\"\n    >\n      <div class=\"shg-box-overlay\"></div><div class=\"shg-box-content\">\n        <div id=\"s-f9ba4fd7-2693-4acb-bb0d-c71455f65011\"  class=\"shg-c  shg-align-left\">\n  <div id=\"rc-landing\" style=\"border:1px solid #d9e5ff; border-radius:14px; padding:16px;\">\n\n  <!-- Flavor selector -->\n  <div style=\"display:flex; gap:10px; margin-bottom:14px; flex-wrap:wrap;\">\n    <button type=\"button\" class=\"flavor-btn active\" data-variant=\"47039934038246\">Tropical Punch</button>\n    <button type=\"button\" class=\"flavor-btn\" data-variant=\"47039943573734\">Concord Grape</button>\n    <button type=\"button\" class=\"flavor-btn\" data-variant=\"47039948292326\">Berry Blast</button>\n  </div>\n\n  <!-- Purchase options -->\n  <div style=\"display:grid; gap:10px; margin-bottom:12px;\">\n    <label class=\"purchase-row\">\n      <input type=\"radio\" name=\"purchase_type\" value=\"onetime\" checked />\n      <div class=\"purchase-box\">\n        <div style=\"display:flex; justify-content:space-between; align-items:center;\">\n          <strong>One-time</strong>\n          <span class=\"price\">$38.97</span>\n        </div>\n      </div>\n    </label>\n\n    <label class=\"purchase-row\">\n      <input type=\"radio\" name=\"purchase_type\" value=\"sub\" />\n      <div class=\"purchase-box\">\n        <div style=\"display:flex; justify-content:space-between; align-items:center; gap:10px;\">\n          <div>\n            <strong>Subscribe & Lock In Price</strong>\n            <div style=\"font-size:13px; margin-top:6px; line-height:1.35;\">\n              ✓ Lock in automatic savings<br>\n              ✓ Stay stocked on everyday favorites<br>\n             