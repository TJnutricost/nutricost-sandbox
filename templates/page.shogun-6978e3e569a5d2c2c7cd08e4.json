    "custom_liquid_4f283bd8-fd9b-457d-bb41-1e231e1d5aab": {
      "type": "custom-liquid",
      "settings": {
        "title": "Custom Liquid",
        "subtitle": "Describe about this section...",
        "custom_liquid": "{% comment %} 1. FETCH PRODUCT {% endcomment %}\n{% assign my_product = all_products['nutricost-clear-whey-protein-isolate'] %}\n\n{% if my_product.id == blank %}\n  <p style=\"color:red;\">Error: Product handle not found.</p>\n{% else %}\n\n  {% form 'product', my_product %}\n    \n    {% comment %} 2. SUBSCRIPTION SELECTORS (The Missing Part) {% endcomment %}\n    {% if my_product.selling_plan_groups.size > 0 %}\n      <div class=\"subscription-wrapper\" style=\"border: 1px solid #ddd; padding: 15px; margin-bottom: 20px; border-radius: 5px;\">\n        \n        <input type=\"hidden\" name=\"selling_plan\" id=\"selling_plan_id\" value=\"\">\n\n        <div style=\"margin-bottom: 10px;\">\n          <label style=\"cursor: pointer; display: flex; align-items: center;\">\n            <input type=\"radio\" name=\"purchase_type\" value=\"onetime\" checked onchange=\"updatePlan('')\" style=\"margin-right: 10px;\">\n            <span>One-time purchase ({{ my_product.price | money }})</span>\n          </label>\n        </div>\n\n        <div>\n          <label style=\"cursor: pointer; display: flex; align-items: center;\">\n            <input type=\"radio\" name=\"purchase_type\" value=\"sub\" onchange=\"updatePlan(this.dataset.planId)\" \n                   data-plan-id=\"{{ my_product.selling_plan_groups[0].selling_plans[0].id }}\" style=\"margin-right: 10px;\">\n            <span>Subscribe & Save (Save 10% - 20%)</span>\n          </label>\n\n          <div id=\"frequency-selector\" style=\"margin-top: 10px; margin-left: 25px; display: none;\">\n            <select onchange=\"document.getElementById('selling_plan_id').value = this.value;\" style=\"padding: 5px;\">\n              {% for group in my_product.selling_plan_groups %}\n                {% for plan in group.selling_plans %}\n                  <option value=\"{{ plan.id }}\">{{ plan.name }}</option>\n                {% endfor %}\n              {% endfor %}\n            </select>\n          </div>\n        </div>\n\n      </div>\n      \n      <script>\n        function updatePlan(planId) {\n          // Update the hidden input that goes to the cart\n          document.getElementById('selling_plan_id').value = planId;\n          \n          // Show/Hide the dropdown based on choice\n          var freqDiv = document.getElementById('frequency-selector');\n          if (planId === '') {\n             freqDiv.style.display = 'none'; // One-time selected\n          } else {\n             freqDiv.style.display = 'block'; // Subscription selected\n          }\n        }\n      </script>\n    {% endif %}\n\n    {% comment %} 3. VARIANT PICKER {% endcomment %}\n    <label style=\"display:block; margin-bottom: 5px; font-weight: bold;\">Select Flavor:</label>\n    <select name=\"id\" style=\"display: block; margin-bottom: 15px; padding: 10px; width: 100%;\">\n      {% for variant in my_product.variants %}\n        <option value=\"{{ variant.id }}\">\n          {{ variant.title }}\n        </option>\n      {% endfor %}\n    </select>\n\n    {% comment %} 4. SUBMIT BUTTON {% endcomment %}\n    <button type=\"submit\" style=\"background: #000; color: #fff; padding: 15px; width: 100%; border: none; font-weight: bold; cursor: pointer;\">\n      ADD TO CART\n    </button>\n    \n  {% endform %}\n{% endif %}",
        "top-offeset": "default",
        "section_cov": false,
        "sec_bg_clr": "#fafafa"
      },
      "custom_css": []
    },
